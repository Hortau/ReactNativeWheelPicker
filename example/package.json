{
  "name": "example",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "yarn pod:install && react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "pod:install": "cd ios && bundle exec pod install && cd ..",
    "pod:update": "cd ios && bundle exec pod update && cd ..",
    "purge:android": "(cd android && ./gradlew --stop) && rm -rf ~/.gradle/caches android/app/build",
    "purge:ios": "rm -rf ios/Pods ios/build ~/Library/Caches/CocoaPods ~/Library/Developer/Xcode/DerivedData && cd ios && bundle exec pod cache clean --all && cd ..",
    "purge:js": "watchman watch-del-all && killall -9 node && rm -rf node_modules && yarn cache clean",
    "purge": "yarn purge:js && yarn purge:android && yarn purge:ios"
  },
  "engines": {
    "node": ">= 20",
    "yarn": ">= 1",
    "npm": "please-use-yarn"
  },
  "packageManager": "yarn@1.22.19",
  "dependencies": {
    "@hortau/react-native-wheel-picker-android": "../",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-picker/picker": "2.11.4",
    "moment": "2.30.1",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-edge-to-edge": "1.8.1",
    "react-native-safe-area-context": "5.7.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/runtime": "7.29.2",
    "@eslint/compat": "2.0.2",
    "@eslint/eslintrc": "3.3.4",
    "@eslint/js": "9.39.3",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.6",
    "@react-native/eslint-config": "0.81.6",
    "@react-native/metro-config": "0.81.6",
    "@react-native/typescript-config": "0.81.6",
    "@types/jest": "30.0.0",
    "@types/react": "19.1.4",
    "@types/react-test-renderer": "19.1.0",
    "babel-jest": "30.3.0",
    "eslint": "9.39.3",
    "eslint-plugin-ft-flow": "3.0.11",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "react-test-renderer": "19.1.0",
    "typescript": "5.5.4"
  }
}
